rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll([
          'name',
          'whatsapp',
          'city',
          'sold_before',
          'market_level',
          'created_at',
          'source'
        ]) &&
        request.resource.data.keys().hasOnly([
          'name',
          'whatsapp',
          'city',
          'sold_before',
          'market_level',
          'created_at',
          'source'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.whatsapp is string &&
        request.resource.data.whatsapp.size() >= 14 &&
        request.resource.data.whatsapp.size() <= 15 &&
        request.resource.data.whatsapp.matches('\\([0-9]{2}\\) [0-9]{4,5}-[0-9]{4}') &&
        request.resource.data.city is string &&
        request.resource.data.city.size() >= 2 &&
        request.resource.data.city.size() <= 120 &&
        request.resource.data.sold_before in ['sim', 'nao'] &&
        request.resource.data.market_level in ['iniciante', 'conheco', 'atuo', 'empresa'] &&
        request.resource.data.created_at == request.time &&
        request.resource.data.source is string &&
        request.resource.data.source.size() <= 500 &&
        request.resource.data.source.matches('https://alexsandercb\\.github\\.io/mentorshanghai/.*');

      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
